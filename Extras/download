<script>
// ── Auto date ───────────────────────────────────────────────────
document.getElementById('fecha').value = new Date().toLocaleDateString('es-MX', {
  year: 'numeric', month: 'long', day: 'numeric'
});

// ── Progress bar: update as user fills sections ─────────────────
function updateProgress() {
  const sections = document.querySelectorAll('.form-section');
  let filled = 0;
  sections.forEach(sec => {
    const inputs = sec.querySelectorAll('input:not([readonly]),select,textarea');
    const hasValue = Array.from(inputs).some(i =>
      (i.type === 'checkbox' || i.type === 'radio') ? i.checked : i.value.trim() !== ''
    );
    if (hasValue) filled++;
  });
  const steps = document.querySelectorAll('.progress-steps .step');
  steps.forEach((s, i) => {
    s.classList.remove('active','done');
    if (i < filled - 1) s.classList.add('done');
    else if (i === filled - 1 || (filled === 0 && i === 0)) s.classList.add('active');
  });
}
document.getElementById('briefForm').addEventListener('change', updateProgress);
document.getElementById('briefForm').addEventListener('input', updateProgress);

// ── Limit "problemas" checkboxes to 3 ─────────────────────────
document.querySelectorAll('input[name="problemas[]"]').forEach(cb => {
  cb.addEventListener('change', () => {
    const checked = document.querySelectorAll('input[name="problemas[]"]:checked');
    if (checked.length > 3) {
      cb.checked = false;
    }
  });
});

// ── Form submit via fetch → submit.php ─────────────────────────
document.getElementById('briefForm').addEventListener('submit', async function(e) {
  e.preventDefault();

  const btn = document.getElementById('submitBtn');
  const alert = document.getElementById('alertBox');
  alert.className = 'alert';
  alert.textContent = '';

  // Basic validation
  const required = ['empresa','nombre','email'];
  let valid = true;
  required.forEach(id => {
    const el = document.getElementById(id);
    if (!el.value.trim()) {
      el.style.borderColor = 'var(--error)';
      valid = false;
    } else {
      el.style.borderColor = '';
    }
  });
  if (!valid) {
    alert.className = 'alert error show';
    alert.textContent = '⚠️ Por favor completa los campos obligatorios: Empresa, Nombre y Correo.';
    alert.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Enviando...';

  try {
    const formData = new FormData(this);
    const res = await fetch('submit.php', { method: 'POST', body: formData });
    const json = await res.json();

    if (json.success) {
      alert.className = 'alert success show';
      alert.innerHTML = '✅ <strong>¡Gracias!</strong> Recibimos tu diagnóstico. ' +
        'Nos pondremos en contacto contigo en menos de 24 horas para agendar tu sesión.';
      this.reset();
      document.getElementById('fecha').value = new Date().toLocaleDateString('es-MX',
        { year: 'numeric', month: 'long', day: 'numeric' });
      btn.textContent = 'Enviado ✓';
    } else {
      throw new Error(json.message || 'Error desconocido');
    }
  } catch (err) {
    alert.className = 'alert error show';
    alert.innerHTML = '❌ Hubo un problema al enviar. Por favor intenta de nuevo o escríbenos a ' +
      '<a href="mailto:ivan@innogyzer.com">ivan@innogyzer.com</a>';
    btn.disabled = false;
    btn.textContent = 'Enviar diagnóstico →';
  }

  alert.scrollIntoView({ behavior: 'smooth', block: 'center' });
});
</script>
